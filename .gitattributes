# Auto detect text files and perform LF normalization
* text=auto

# Bash scripts should always use LF
*.sh text eol=lf

# Python scripts should always use LF
*.py text eol=lf

# Markdown files should always use LF
*.md text eol=lf

# JSON files should always use LF
*.json text eol=lf

# YAML files should always use LF
*.yaml text eol=lf
*.yml text eol=lf
